TRADENODEX_AAT_DB_PATH=./data/tradenodex_aat.sqlite3
TRADENODEX_AAT_OPERATOR_TOKEN=change-me-replace-before-use
TRADENODEX_AAT_ENCRYPTION_KEY=change-this-strong-random-key-before-production
TRADENODEX_AAT_ENABLE_LIVE_TRADING=false
TRADENODEX_AAT_DEFAULT_DRY_RUN=true
TRADENODEX_AAT_TICK_SECONDS=15
TRADENODEX_AAT_WORKER_INTERVAL_SECONDS=10
TRADENODEX_AAT_RECONCILE_EVERY_TICKS=6
TRADENODEX_AAT_API_BASE=http://127.0.0.1:8000
TRADENODEX_AAT_MAX_RETRY_ATTEMPTS=3
TRADENODEX_AAT_MARKET_STREAM_ENABLED=false
TRADENODEX_AAT_RATE_LIMIT_PER_MINUTE=60
TRADENODEX_AAT_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
TRADENODEX_AAT_BINANCE_TESTNET_DEFAULT_LEVERAGE=1
TRADENODEX_AAT_BINANCE_TESTNET_MARGIN_MODE=ISOLATED
TRADENODEX_AAT_BINANCE_MAINNET_DEFAULT_LEVERAGE=1
TRADENODEX_AAT_BINANCE_MAINNET_MARGIN_MODE=ISOLATED
TRADENODEX_AAT_GLOBAL_MAX_ORDER_NOTIONAL_USDT=100
TRADENODEX_AAT_GLOBAL_DAILY_LOSS_LIMIT_USDT=50

# Single-account fast-copy engine. Default is safe dry-run behavior.
TRADENODEX_AAT_COPY_ENGINE_ENABLED=true
TRADENODEX_AAT_COPY_PRIMARY_ACCOUNT_ID=
TRADENODEX_AAT_COPY_DEFAULT_SYMBOL=BTCUSDT
TRADENODEX_AAT_COPY_DEFAULT_NOTIONAL_USDT=5
TRADENODEX_AAT_COPY_MAX_SIGNAL_QUEUE_SIZE=5000
TRADENODEX_AAT_COPY_MAX_CONCURRENT_EXECUTIONS=4
TRADENODEX_AAT_COPY_MAX_SLIPPAGE_BPS=30
TRADENODEX_AAT_COPY_DEFAULT_MULTIPLIER=1
TRADENODEX_AAT_COPY_USER_STREAM_ENABLED=false

# Binance USDT-M Futures Testnet credentials. Never commit real values.
TRADENODEX_AAT_BINANCE_FUTURES_TESTNET_API_KEY=
TRADENODEX_AAT_BINANCE_FUTURES_TESTNET_API_SECRET=

TRADENODEX_AAT_TELEGRAM_BOT_TOKEN=
TRADENODEX_AAT_TELEGRAM_CHAT_ID=
TRADENODEX_AAT_ALERT_WEBHOOK_URL=
TRADENODEX_AAT_SMTP_HOST=
TRADENODEX_AAT_SMTP_PORT=587
TRADENODEX_AAT_SMTP_USER=
TRADENODEX_AAT_SMTP_PASSWORD=
TRADENODEX_AAT_SMTP_FROM=
TRADENODEX_AAT_SMTP_TO=
